# Mycelium Protocol -- Environment Configuration
# Copy to .env and fill in values for your target network.

# ── Network Selection ──────────────────────────────────────────────
# Controls default program IDs and USDC mint across all adapters.
# Values: "devnet" | "mainnet-beta"
SOLANA_NETWORK=devnet

# ── Solana Connection ──────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
# For mainnet: https://api.mainnet-beta.solana.com
# For Helius RPC: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

SOLANA_KEYPAIR_PATH=~/solana-keys/id.json

# ── Helius (optional, for indexing) ────────────────────────────────
HELIUS_API_KEY=

# ── Program IDs (override defaults per-network) ───────────────────
# Only set these if you need to override the built-in defaults.
# Devnet defaults are used when SOLANA_NETWORK=devnet.
# Mainnet defaults are used when SOLANA_NETWORK=mainnet-beta.

# MYCELIUM_SPORE_PROGRAM_ID=GQKhpugP3tECnV64WVQoBRQembMcaW35CDPpLzGTprrR
# MYCELIUM_HYPHA_PROGRAM_ID=BWaYdvceTLCR4T2E67C4uNrxxDQH5fDMDtL4kqdMPjuV
# MYCELIUM_RHIZOME_PROGRAM_ID=7nKmtUgSaZTgF5fMcjQw1LR8nfKG8kgLauqAmtC3qJWW
# MYCELIUM_MERIDIAN_PROGRAM_ID=2PBZSAN2LSoGHWsWmr6kFBtrVHicTvTHiZBF8Y4B54Le
# MYCELIUM_DRP_PROGRAM_ID=BKrUCdqyVLywaT3WhLcKkLZ4nEib3K9ZXA4bVd7xbifU

# ── USDC Mint ──────────────────────────────────────────────────────
# Auto-selected based on SOLANA_NETWORK. Override only if needed.
# Devnet:  4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ── Database (for indexer) ─────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/mycelium

# ── Irys/Arweave (for evidence engine) ────────────────────────────
# Uses SOLANA_KEYPAIR_PATH wallet for funding uploads.
# Ensure sufficient SOL balance for Arweave storage fees.
