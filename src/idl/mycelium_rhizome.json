{
  "version": "0.1.0",
  "name": "mycelium_rhizome",
  "address": "7nKmtUgSaZTgF5fMcjQw1LR8nfKG8kgLauqAmtC3qJWW",
  "instructions": [
    {
      "name": "configureRoyalty",
      "accounts": [
        { "name": "royaltyConfig", "isMut": true, "isSigner": false },
        { "name": "ipAsset", "isMut": false, "isSigner": false },
        { "name": "creator", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "recipients", "type": { "vec": { "defined": "RoyaltyRecipient" } } },
        { "name": "platformFeeBps", "type": "u16" },
        { "name": "platformWallet", "type": "publicKey" }
      ]
    },
    {
      "name": "depositRoyalty",
      "accounts": [
        { "name": "royaltyConfig", "isMut": true, "isSigner": false },
        { "name": "royaltyVault", "isMut": true, "isSigner": false },
        { "name": "depositor", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "amountLamports", "type": "u64" }
      ]
    },
    {
      "name": "distributeRoyalties",
      "accounts": [
        { "name": "royaltyConfig", "isMut": true, "isSigner": false },
        { "name": "royaltyVault", "isMut": true, "isSigner": false },
        { "name": "distributionPool", "isMut": true, "isSigner": false },
        { "name": "platformWallet", "isMut": true, "isSigner": false },
        { "name": "caller", "isMut": false, "isSigner": true }
      ],
      "args": []
    }
  ],
  "accounts": [
    {
      "name": "RoyaltyConfig",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "ipAsset", "type": "publicKey" },
          { "name": "creator", "type": "publicKey" },
          { "name": "platformWallet", "type": "publicKey" },
          { "name": "platformFeeBps", "type": "u16" },
          { "name": "totalDeposited", "type": "u64" },
          { "name": "totalDistributed", "type": "u64" },
          { "name": "distributionCount", "type": "u32" },
          { "name": "isActive", "type": "bool" },
          { "name": "recipientCount", "type": "u8" },
          { "name": "recipients", "type": { "vec": { "defined": "RoyaltyRecipient" } } },
          { "name": "bump", "type": "u8" }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "RoyaltyRecipient",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "wallet", "type": "publicKey" },
          { "name": "shareBps", "type": "u16" },
          { "name": "role", "type": { "defined": "RecipientRole" } }
        ]
      }
    },
    {
      "name": "RecipientRole",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Creator" },
          { "name": "CoCreator" },
          { "name": "ParentIP" },
          { "name": "Platform" },
          { "name": "Other" }
        ]
      }
    }
  ],
  "events": [
    {
      "name": "RoyaltyConfigured",
      "fields": [
        { "name": "configKey", "type": "publicKey", "index": false },
        { "name": "ipAsset", "type": "publicKey", "index": false },
        { "name": "creator", "type": "publicKey", "index": false },
        { "name": "recipientCount", "type": "u8", "index": false },
        { "name": "platformFeeBps", "type": "u16", "index": false }
      ]
    },
    {
      "name": "RoyaltyDeposited",
      "fields": [
        { "name": "configKey", "type": "publicKey", "index": false },
        { "name": "ipAsset", "type": "publicKey", "index": false },
        { "name": "depositor", "type": "publicKey", "index": false },
        { "name": "amountLamports", "type": "u64", "index": false },
        { "name": "totalDeposited", "type": "u64", "index": false }
      ]
    },
    {
      "name": "RoyaltiesDistributed",
      "fields": [
        { "name": "configKey", "type": "publicKey", "index": false },
        { "name": "ipAsset", "type": "publicKey", "index": false },
        { "name": "totalDistributed", "type": "u64", "index": false },
        { "name": "platformFee", "type": "u64", "index": false },
        { "name": "recipientAmount", "type": "u64", "index": false },
        { "name": "distributionNumber", "type": "u32", "index": false }
      ]
    }
  ],
  "errors": [
    { "code": 6000, "name": "InvalidRecipientCount", "msg": "Must have between 1 and 8 recipients" },
    { "code": 6001, "name": "PlatformFeeTooHigh", "msg": "Platform fee cannot exceed 1000 bps (10%)" },
    { "code": 6002, "name": "SplitsMustSum10000", "msg": "Recipient shares must sum to exactly 10000 bps (100%)" },
    { "code": 6003, "name": "ZeroDeposit", "msg": "Deposit amount must be greater than zero" },
    { "code": 6004, "name": "ConfigNotActive", "msg": "Royalty config is not active" },
    { "code": 6005, "name": "NothingToDistribute", "msg": "Nothing to distribute -- vault is empty" },
    { "code": 6006, "name": "Overflow", "msg": "Arithmetic overflow" },
    { "code": 6007, "name": "Unauthorized", "msg": "Unauthorized: caller or platform wallet does not match configuration" }
  ]
}
